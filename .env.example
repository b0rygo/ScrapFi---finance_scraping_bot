# =====================================================================
#  ScrapFi – konfiguracja. Skopiuj ten plik do ".env" i uzupełnij klucze.
#      cp .env.example .env        (Linux/RaspberryPi)
#      copy .env.example .env      (Windows)
#  Pliku .env NIGDY nie commituj do gita (jest w .gitignore).
# =====================================================================

# --- Telegram (WYMAGANE) ------------------------------------------------
# Token od @BotFather (/newbot).
TELEGRAM_BOT_TOKEN=123456789:AA...twój_token...
# Twoje prywatne chat_id (od @userinfobot). Tylko ten czat ma dostęp do bota.
TELEGRAM_ALLOWED_CHAT_ID=123456789

# --- Notowania giełdowe (WYMAGANE) --------------------------------------
# Finnhub – skaner co 3 min + newsy spółek.  https://finnhub.io/register
FINNHUB_API_KEY=twój_klucz_finnhub

# --- Top Gainers (zalecane; bez klucza użyty zostanie fallback yfinance) -
# Financial Modeling Prep.  https://site.financialmodelingprep.com/
FMP_API_KEY=twój_klucz_fmp

# --- Analiza AI (WYMAGANE dla raportu dziennego) ------------------------
# Google AI Studio.  https://aistudio.google.com/apikey
GEMINI_API_KEY=twój_klucz_gemini
GEMINI_MODEL=gemini-2.5-flash

# --- Moduł 2: skaner krótkoterminowy ------------------------------------
# Lista obserwowanych spółek (tickery US, po przecinku).
WATCHLIST=AAPL,MSFT,NVDA,TSLA,AMD,GOOGL,AMZN,META
# Co ile minut skanować.
SCANNER_INTERVAL_MINUTES=3
# Próg alertu: skok > X% w oknie jednego skanu (3 min).
SCANNER_THRESHOLD_PCT=1.5
# Czy alarmować też o spadkach (true) czy tylko o wzrostach (false).
SCANNER_ALERT_ON_DROPS=false
# Ile minut ciszy dla danej spółki po alercie (żeby nie spamować co 3 min).
SCANNER_COOLDOWN_MINUTES=15
# Odstęp między zapytaniami do Finnhub (sekundy) – ochrona przed limitem.
SCANNER_CALL_DELAY_SECONDS=0.5

# --- Moduł 1: dzienny raport Top Gainers + AI ---------------------------
# Godzina wysyłki raportu (HH:MM) w strefie DAILY_REPORT_TIMEZONE.
DAILY_REPORT_TIME=08:30
DAILY_REPORT_TIMEZONE=America/New_York
# Dni tygodnia wg python-telegram-bot: 0=niedz, 1=pon, 2=wt, 3=śr, 4=czw, 5=pt, 6=sob.
# Domyślnie dni handlowe giełdy (poniedziałek-piątek) = 1,2,3,4,5.
DAILY_REPORT_DAYS=1,2,3,4,5
# Ile najlepszych spółek analizować (3-5).
TOP_GAINERS_COUNT=5
# Newsy: ile dni wstecz i ile nagłówków na spółkę do analizy AI.
NEWS_LOOKBACK_DAYS=3
NEWS_MAX_HEADLINES=6

# --- Różne --------------------------------------------------------------
LOG_LEVEL=INFO
